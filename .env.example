# Variáveis de Ambiente para Desenvolvimento
# Copie este arquivo para .env e preencha os valores

# Database Connection Strings (Local Development)
ConnectionStrings__DefaultConnection=Server=(localdb)\\mssqllocaldb;Database=Recruiva.Dev;Trusted_Connection=True;MultipleActiveResultSets=true

# SendGrid (Email)
SENDGRID_API_KEY=
SendGRID__FromEmail=noreply@recruiva.com
SendGRID__FromName=Recruiva

# ASP.NET Core
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:80

# Database (Docker)
DB_PASSWORD=YourStrong@Passw0rd
DB_SERVER=localhost
DB_NAME=RecruivaDB
DB_USER=sa

# RabbitMQ (Docker)
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# Security (Production)
ASPNETCORE_Kestrel__Certificates__Default__Path=
ASPNETCORE_Kestrel__Certificates__Default__Password=

# Docker-specific
# Use uma senha forte para o SQL Server em Docker
# Mínimo 8 caracteres, incluindo maiúsculas, minúsculas, números e caracteres especiais

