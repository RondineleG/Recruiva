@page "/jobs/{jobId:guid}"
@using Recruiva.Core.DTOs.Response
@using Recruiva.Core.Enums
@using Recruiva.Core.UseCases.Jobs
@inject GetJobByIdUseCase GetJobByIdUseCase
@inject NavigationManager Navigation

<PageTitle>@(job?.Title ?? "Detalhes da Vaga") - Recruiva</PageTitle>

<HeadContent>
    @if (job != null)
    {
        <meta name="description" content="@job.Title - @(job.AdvertiserName ?? "Empresa confidencial") em @(!string.IsNullOrEmpty(job.City) ? $"{job.City}, {job.State}" : "Localização a combinar")" />
        <meta property="og:title" content="@job.Title - Recruiva" />
        <meta property="og:description" content="@job.Description.Substring(0, Math.Min(160, job.Description.Length))..." />
        <meta property="og:type" content="article" />
        <meta property="og:url" content="@Navigation.Uri" />
    }
    else
    {
        <meta name="description" content="Detalhes da vaga - Recruiva" />
        <meta property="og:title" content="Recruiva - Detalhes da Vaga" />
        <meta property="og:description" content="Veja os detalhes desta vaga e candidate-se" />
        <meta property="og:type" content="website" />
    }
</HeadContent>

<div class="container mt-4">
    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Carregando...</span>
            </div>
            <p class="mt-2">Carregando detalhes da vaga...</p>
        </div>
    }
    else if (job == null)
    {
        <div class="alert alert-danger">
            <i class="bi bi-exclamation-triangle"></i> Vaga não encontrada.
        </div>
        <button class="btn btn-primary" @onclick="NavigateBackToList">
            ← Voltar para lista de vagas
        </button>
    }
    else
    {
        <!-- Breadcrumb -->
        <nav aria-label="breadcrumb" class="mb-4">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/jobs">Vagas</a></li>
                <li class="breadcrumb-item active">@job.Title</li>
            </ol>
        </nav>

        <div class="row">
            <!-- Detalhes da Vaga -->
            <div class="col-lg-8">
                <div class="card mb-4">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h1 class="card-title">@job.Title</h1>
                            @if (job.IsRemote)
                            {
                                <span class="badge bg-success fs-6">🏠 Remoto</span>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(job.AdvertiserName))
                        {
                            <h5 class="text-muted mb-3">
                                <i class="bi bi-building"></i> @job.AdvertiserName
                            </h5>
                        }

                        <div class="row mb-3">
                            @if (!string.IsNullOrEmpty(job.City))
                            {
                                <div class="col-md-6 mb-2">
                                    <strong><i class="bi bi-geo-alt"></i> Localização:</strong><br />
                                    @job.City, @job.State
                                </div>
                            }
                            
                            @if (job.SalaryDisplay && job.SalaryMin.HasValue && job.SalaryMax.HasValue)
                            {
                                <div class="col-md-6 mb-2">
                                    <strong><i class="bi bi-currency-exchange"></i> Salário:</strong><br />
                                    <span class="text-success">
                                        R$ @job.SalaryMin.Value.ToString("N2") - R$ @job.SalaryMax.Value.ToString("N2") @job.SalaryCurrency
                                    </span>
                                </div>
                            }

                            <div class="col-md-6 mb-2">
                                <strong><i class="bi bi-tag"></i> Tipo:</strong><br />
                                @(job.Type == "OnSite" ? "Presencial" : job.Type == "Remote" ? "Remoto" : "Híbrido")
                            </div>

                            @if (!string.IsNullOrEmpty(job.Category))
                            {
                                <div class="col-md-6 mb-2">
                                    <strong><i class="bi bi-bookmark"></i> Categoria:</strong><br />
                                    <span class="badge bg-info">@job.Category</span>
                                </div>
                            }
                        </div>

                        <hr />

                        <div class="mb-4">
                            <h4><i class="bi bi-list-check"></i> Descrição da Vaga</h4>
                            <p class="mt-2">@job.Description</p>
                        </div>

                        @if (!string.IsNullOrEmpty(job.Requirements))
                        {
                            <div class="mb-4">
                                <h4><i class="bi bi-check2-circle"></i> Requisitos</h4>
                                <p class="mt-2">@job.Requirements</p>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(job.Responsibilities))
                        {
                            <div class="mb-4">
                                <h4><i class="bi bi-briefcase"></i> Responsabilidades</h4>
                                <p class="mt-2">@job.Responsibilities</p>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(job.Benefits))
                        {
                            <div class="mb-4">
                                <h4><i class="bi bi-gift"></i> Benefícios</h4>
                                <p class="mt-2">@job.Benefits</p>
                            </div>
                        }

                        @if (!string.IsNullOrEmpty(job.Tags))
                        {
                            <div class="mb-3">
                                <strong>Tags:</strong>
                                @foreach (var tag in job.Tags.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                                {
                                    <span class="badge bg-secondary me-1">@tag</span>
                                }
                            </div>
                        }

                        <div class="text-muted small">
                            <i class="bi bi-calendar"></i> Publicada em: @job.CreatedAt.ToString("dd/MM/yyyy")<br />
                            <i class="bi bi-clock-history"></i> Expira em: @job.ExpirationDate.ToString("dd/MM/yyyy")<br />
                            <i class="bi bi-eye"></i> @job.Views visualizações | 
                            <i class="bi bi-people"></i> @job.Applications candidaturas
                        </div>
                    </div>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="col-lg-4">
                <!-- Card de Candidatura -->
                <div class="card mb-3">
                    <div class="card-body">
                        <h5 class="card-title">Interessado nesta vaga?</h5>
                        <p class="card-text">Candidate-se agora e demonstre seu interesse!</p>
                        <button class="btn btn-success w-100 btn-lg" @onclick="ApplyToJob">
                            <i class="bi bi-send"></i> Candidatar-se
                        </button>
                    </div>
                </div>

                <!-- Card da Empresa -->
                @if (!string.IsNullOrEmpty(job.AdvertiserName))
                {
                    <div class="card">
                        <div class="card-body">
                            <h6 class="card-title">Sobre a Empresa</h6>
                            @if (!string.IsNullOrEmpty(job.AdvertiserLogoUrl))
                            {
                                <img src="@job.AdvertiserLogoUrl" alt="Logo" class="img-fluid mb-2" style="max-height: 80px;" />
                            }
                            <p class="card-text"><strong>@job.AdvertiserName</strong></p>
                            <button class="btn btn-outline-primary btn-sm w-100">
                                Ver perfil da empresa
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Botões de Ação -->
        <div class="mt-4">
            <button class="btn btn-secondary" @onclick="NavigateBackToList">
                ← Voltar para lista de vagas
            </button>
        </div>
    }
</div>

@code {
    [Parameter]
    public Guid JobId { get; set; }

    private JobResponse? job;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        var result = await GetJobByIdUseCase.ExecuteAsync(JobId);
        if (result.Status == EResultStatus.Success)
        {
            job = result.Data;
        }
        isLoading = false;
    }

    private void ApplyToJob()
    {
        Navigation.NavigateTo($"/apply/{JobId}");
    }

    private void NavigateBackToList()
    {
        Navigation.NavigateTo("/jobs");
    }
}
