@page "/apply/{jobId:guid}"
@using Recruiva.Core.DTOs.Request
@using Recruiva.Core.Enums
@using Recruiva.Core.UseCases.Applications
@using Recruiva.Web.Services
@inject CreateApplicationUseCase CreateApplicationUseCase
@inject ICurrentUserHelper CurrentUserHelper
@inject NavigationManager Navigation

<PageTitle>Candidatar-se - Recruiva</PageTitle>

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>📝 Candidatar-se à Vaga</h1>
                <button class="btn btn-secondary" @onclick="Cancel">
                    ← Cancelar
                </button>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle"></i> @errorMessage
                </div>
            }

            @if (successMessage)
            {
                <div class="alert alert-success">
                    <i class="bi bi-check-circle"></i> Candidatura realizada com sucesso!
                    <br />
                    <button class="btn btn-primary mt-2" @onclick="ViewApplications">
                        Ver Minhas Candidaturas
                    </button>
                </div>
            }
            else
            {
                <div class="card">
                    <div class="card-body">
                        <p class="text-muted">
                            Você está se candidatando à vaga <strong>@jobTitle</strong>.
                            <br />
                            Preencha as informações abaixo (opcional):
                        </p>

                        <EditForm Model="model" OnValidSubmit="SubmitForm">
                            <DataAnnotationsValidator />

                            <div class="mb-3">
                                <label class="form-label">Observações (opcional)</label>
                                <InputTextArea class="form-control" @bind-Value="model.Notes" rows="4" 
                                    placeholder="Escreva uma breve mensagem ou destaque suas qualificações..." />
                            </div>

                            <div class="alert alert-info">
                                <i class="bi bi-info-circle"></i> 
                                Seu currículo ativo será enviado automaticamente.
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-success btn-lg" disabled="isSubmitting">
                                    @if (isSubmitting)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                    }
                                    <i class="bi bi-send"></i> Enviar Candidatura
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public Guid JobId { get; set; }

    private CreateApplicationRequest model = new();
    private string errorMessage = string.Empty;
    private bool successMessage = false;
    private bool isSubmitting = false;
    private string jobTitle = "carregando...";

    protected override async Task OnInitializedAsync()
    {
        // TODO: Obter título da vaga
        jobTitle = $"Vaga {JobId.ToString().Substring(0, 8)}";

        // Obter CandidateId do usuário logado
        var candidateId = CurrentUserHelper.GetCandidateId();
        if (candidateId.HasValue)
        {
            model.CandidateId = candidateId.Value;
        }
        model.JobId = JobId;
    }

    private async Task SubmitForm()
    {
        isSubmitting = true;
        errorMessage = string.Empty;

        var result = await CreateApplicationUseCase.ExecuteAsync(model);
        
        if (result.Status == EResultStatus.Success)
        {
            successMessage = true;
        }
        else
        {
            errorMessage = result.Message;
        }

        isSubmitting = false;
    }

    private void Cancel()
    {
        Navigation.NavigateTo($"/jobs/{JobId}");
    }

    private void ViewApplications()
    {
        Navigation.NavigateTo("/my-applications");
    }
}
