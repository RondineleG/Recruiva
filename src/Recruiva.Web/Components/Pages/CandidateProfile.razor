@page "/profile/candidate"

<PageTitle>Meu Perfil - Recruiva</PageTitle>

<div class="container mt-4">
    <h1>👤 Meu Perfil de Candidato</h1>
    
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> 
        Funcionalidade em desenvolvimento. Em breve você poderá editar seu perfil aqui.
    </div>

    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">Dados Pessoais</h5>
                    <p class="card-text text-muted">Nome, email, telefone e data de nascimento</p>
                    <button class="btn btn-outline-primary btn-sm" disabled>Editar (Em breve)</button>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card">
                <div class="card-body">
                    <h5 class="card-title">LinkedIn</h5>
                    <p class="card-text text-muted">Integração com seu perfil do LinkedIn</p>
                    <button class="btn btn-outline-primary btn-sm" disabled>Conectar (Em breve)</button>
                </div>
            </div>
        </div>
    </div>
</div>
