@page "/my-applications"
@using Recruiva.Core.Enums

<PageTitle>Minhas Candidaturas - Recruiva</PageTitle>

<div class="container mt-4">
    <h1>📋 Minhas Candidaturas</h1>
    
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> 
        Funcionalidade em desenvolvimento. Em breve você poderá acompanhar todas as suas candidaturas aqui.
    </div>

    <div class="text-center mt-5">
        <i class="bi bi-send display-1 text-muted"></i>
        <h3 class="mt-3">Nenhuma candidatura ainda</h3>
        <p class="text-muted">Candidate-se a vagas para vê-las aqui!</p>
        <a href="/jobs" class="btn btn-primary">
            <i class="bi bi-search"></i> Buscar Vagas
        </a>
    </div>
</div>
