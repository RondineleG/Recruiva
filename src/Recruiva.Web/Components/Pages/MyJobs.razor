@page "/my-jobs"
@using Recruiva.Core.DTOs.Response
@using Recruiva.Core.Enums
@using Recruiva.Core.UseCases.Jobs
@inject SearchJobsUseCase SearchJobsUseCase
@inject NavigationManager Navigation

<PageTitle>Minhas Vagas - Recruiva</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>💼 Minhas Vagas</h1>
        <button class="btn btn-primary" @onclick="@(() => Navigation.NavigateTo("/jobs/create", forceLoad: true))">
            <i class="bi bi-plus-circle"></i> Nova Vaga
        </button>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Carregando suas vagas...</p>
        </div>
    }
    else if (jobs?.Any() == true)
    {
        <!-- Resumo -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body text-center">
                        <h3>@jobs.Count()</h3>
                        <p class="mb-0">Total de Vagas</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body text-center">
                        <h3>@jobs.Count(j => j.Status == "Active")</h3>
                        <p class="mb-0">Ativas</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-white">
                    <div class="card-body text-center">
                        <h3>@jobs.Sum(j => j.Views)</h3>
                        <p class="mb-0">Visualizações</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body text-center">
                        <h3>@jobs.Sum(j => j.Applications)</h3>
                        <p class="mb-0">Candidaturas</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabela de Vagas -->
        <div class="card">
            <div class="card-body">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Título</th>
                            <th>Status</th>
                            <th>Visualizações</th>
                            <th>Candidaturas</th>
                            <th>Expira em</th>
                            <th>Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var job in jobs)
                        {
                            <tr>
                                <td>
                                    <strong>@job.Title</strong>
                                    @if (!string.IsNullOrEmpty(job.Category))
                                    {
                                        <br />
                                        <small class="text-muted"><i class="bi bi-tag"></i> @job.Category</small>
                                    }
                                </td>
                                <td>
                                    @switch (job.Status)
                                    {
                                        case "Active":
                                            <span class="badge bg-success">Ativa</span>
                                            break;
                                        case "Expired":
                                            <span class="badge bg-secondary">Expirada</span>
                                            break;
                                        case "Hidden":
                                            <span class="badge bg-warning">Oculta</span>
                                            break;
                                        case "Rejected":
                                            <span class="badge bg-danger">Rejeitada</span>
                                            break;
                                        case "Paused":
                                            <span class="badge bg-info">Pausada</span>
                                            break;
                                        default:
                                            <span class="badge bg-secondary">@job.Status</span>
                                            break;
                                    }
                                </td>
                                <td><i class="bi bi-eye"></i> @job.Views</td>
                                <td><i class="bi bi-people"></i> @job.Applications</td>
                                <td>
                                    @if (job.ExpirationDate < DateTime.UtcNow)
                                    {
                                        <span class="text-danger"><i class="bi bi-exclamation-triangle"></i> Expirada</span>
                                    }
                                    else
                                    {
                                        @job.ExpirationDate.ToString("dd/MM/yyyy")
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <button class="btn btn-outline-primary" @onclick="() => ViewJob(job.Id)" title="Ver detalhes">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                        <button class="btn btn-outline-warning" @onclick="() => EditJob(job.Id)" title="Editar">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                        <button class="btn btn-outline-info" @onclick="() => ViewApplications(job.Id)" title="Ver candidaturas">
                                            <i class="bi bi-envelope-open"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="text-center mt-5">
            <i class="bi bi-briefcase display-1 text-muted"></i>
            <h3 class="mt-3">Nenhuma vaga criada ainda</h3>
            <p class="text-muted">Crie sua primeira vaga para começar a receber candidaturas!</p>
            <button class="btn btn-primary btn-lg" @onclick="@(() => Navigation.NavigateTo("/jobs/create", forceLoad: true))">
                <i class="bi bi-plus-circle"></i> Criar Minha Primeira Vaga
            </button>
        </div>
    }
</div>

@code {
    private IEnumerable<JobResponse>? jobs;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        // TODO: Filtrar por advertiserId do usuário logado
        var request = new ListJobsRequest
        {
            Page = 1,
            Size = 100
        };

        var result = await SearchJobsUseCase.ExecuteAsync(request);
        if (result.Status == EResultStatus.Success)
        {
            jobs = result.Data?.Jobs;
        }
        
        isLoading = false;
    }

    private void ViewJob(Guid jobId)
    {
        Navigation.NavigateTo($"/jobs/{jobId}");
    }

    private void EditJob(Guid jobId)
    {
        Navigation.NavigateTo($"/jobs/edit/{jobId}");
    }

    private void ViewApplications(Guid jobId)
    {
        Navigation.NavigateTo($"/jobs/{jobId}/applications");
    }
}
