@page "/resumes"

<PageTitle>Meus Currículos - Recruiva</PageTitle>

<div class="container mt-4">
    <h1>📄 Meus Currículos</h1>
    
    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i> 
        Funcionalidade em desenvolvimento. Em breve você poderá criar e gerenciar seus currículos aqui.
    </div>

    <div class="text-center mt-5">
        <i class="bi bi-file-earmark-text display-1 text-muted"></i>
        <h3 class="mt-3">Nenhum currículo criado</h3>
        <p class="text-muted">Crie seu primeiro currículo para se candidatar às vagas!</p>
        <button class="btn btn-primary" disabled>
            <i class="bi bi-plus-circle"></i> Criar Currículo (Em breve)
        </button>
    </div>
</div>
