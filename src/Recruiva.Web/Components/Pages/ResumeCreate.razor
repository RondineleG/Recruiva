@page "/resumes/new"

<PageTitle>Criar Currículo - Recruiva</PageTitle>

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>📝 Criar Novo Currículo</h1>
                <button class="btn btn-secondary" @onclick="Cancel">
                    ← Cancelar
                </button>
            </div>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle"></i> @errorMessage
                </div>
            }

            @if (successMessage)
            {
                <div class="alert alert-success">
                    <i class="bi bi-check-circle"></i> Currículo criado com sucesso!
                    <br />
                    <button class="btn btn-primary mt-2" @onclick="ViewResumes">
                        Ver Meus Currículos
                    </button>
                </div>
            }
            else
            {
                <div class="card">
                    <div class="card-body">
                        <EditForm Model="model" OnValidSubmit="SubmitForm">
                            <DataAnnotationsValidator />

                            <!-- Informações Básicas -->
                            <h5 class="mb-3"><i class="bi bi-info-circle"></i> Informações Básicas</h5>
                            
                            <div class="mb-3">
                                <label class="form-label">Título do Currículo *</label>
                                <InputText class="form-control" @bind-Value="model.Title" 
                                    placeholder="Ex: Desenvolvedor Full Stack Pleno" />
                                <div class="form-text">Um título claro ajuda os recrutadores a entenderem seu perfil</div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Resumo Profissional</label>
                                <InputTextArea class="form-control" @bind-Value="model.Summary" rows="4" 
                                    placeholder="Escreva um breve resumo sobre sua experiência e objetivos profissionais..." />
                                <div class="form-text">Máximo 2000 caracteres</div>
                            </div>

                            <div class="mb-3 form-check">
                                <InputCheckbox class="form-check-input" @bind-Value="model.IsActive" />
                                <label class="form-check-label">
                                    <strong>Definir como currículo ativo</strong>
                                    <br />
                                    <small class="text-muted">Este currículo será usado automaticamente nas candidaturas</small>
                                </label>
                            </div>

                            <hr class="my-4" />

                            <!-- Próximas Seções -->
                            <div class="alert alert-info">
                                <h5><i class="bi bi-info-circle"></i> Seções Adicionais</h5>
                                <p class="mb-2">Após criar o currículo básico, você poderá adicionar:</p>
                                <ul class="mb-0">
                                    <li><strong>🎓 Formação Acadêmica</strong> - Sua educação e cursos</li>
                                    <li><strong>💼 Experiência Profissional</strong> - Trabalhos anteriores</li>
                                    <li><strong>🌍 Idiomas</strong> - Línguas que você domina</li>
                                    <li><strong>⚙️ Habilidades</strong> - Suas competências técnicas</li>
                                </ul>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-success btn-lg" disabled="isSubmitting">
                                    @if (isSubmitting)
                                    {
                                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                                    }
                                    <i class="bi bi-check-circle"></i> Criar Currículo
                                </button>
                            </div>
                        </EditForm>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private CreateResumeRequest model = new()
    {
        IsActive = true
    };
    private string errorMessage = string.Empty;
    private bool successMessage = false;
    private bool isSubmitting = false;

    protected override void OnInitialized()
    {
        // TODO: Obter CandidateId do usuário logado
        model.CandidateId = Guid.Parse("44444444-4444-4444-4444-444444444444");
    }

    private async Task SubmitForm()
    {
        isSubmitting = true;
        errorMessage = string.Empty;

        // TODO: Implementar criação real
        await Task.Delay(100);
        successMessage = true;
        
        isSubmitting = false;
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/resumes");
    }

    private void ViewResumes()
    {
        Navigation.NavigateTo("/resumes");
    }

    [Inject]
    private NavigationManager Navigation { get; set; } = default!;
}
