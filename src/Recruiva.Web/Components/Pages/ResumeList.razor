@page "/resumes"
@page "/resumes/create"
@using Recruiva.Web.Services
@inject ICurrentUserHelper CurrentUserHelper

<PageTitle>Meus Currículos - Recruiva</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>📄 Meus Currículos</h1>
        <button class="btn btn-primary" @onclick="CreateResume">
            <i class="bi bi-plus-circle"></i> Novo Currículo
        </button>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Carregando currículos...</p>
        </div>
    }
    else if (resumes?.Any() == true)
    {
        <div class="row g-3">
            @foreach (var resume in resumes)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 @(resume.IsActive ? "border-success" : "")">
                        <div class="card-body">
                            @if (resume.IsActive)
                            {
                                <span class="badge bg-success mb-2">Ativo</span>
                            }
                            <h5 class="card-title">@resume.Title</h5>
                            @if (!string.IsNullOrEmpty(resume.Summary))
                            {
                                <p class="card-text text-muted small">
                                    @(resume.Summary.Length > 100 ? resume.Summary.Substring(0, 100) + "..." : resume.Summary)
                                </p>
                            }
                            <p class="card-text small text-muted">
                                <i class="bi bi-calendar"></i> Criado em: @resume.CreatedAt.ToString("dd/MM/yyyy")
                            </p>
                        </div>
                        <div class="card-footer bg-transparent">
                            <button class="btn btn-outline-primary btn-sm w-100" @onclick="() => ViewResume(resume.Id)">
                                <i class="bi bi-eye"></i> Ver Currículo
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center mt-5">
            <i class="bi bi-file-earmark-text display-1 text-muted"></i>
            <h3 class="mt-3">Nenhum currículo criado</h3>
            <p class="text-muted">Crie seu primeiro currículo para se candidatar às vagas!</p>
            <button class="btn btn-primary btn-lg" @onclick="CreateResume">
                <i class="bi bi-plus-circle"></i> Criar Meu Primeiro Currículo
            </button>
        </div>
    }
</div>

@code {
    private List<ResumeResponse>? resumes;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        // Obter CandidateId do usuário logado
        var candidateId = CurrentUserHelper.GetCandidateId();

        // TODO: Implementar listagem real
        resumes = new List<ResumeResponse>();
        isLoading = false;
    }

    private void CreateResume()
    {
        Navigation.NavigateTo("/resumes/new");
    }

    private void ViewResume(Guid resumeId)
    {
        Navigation.NavigateTo($"/resumes/{resumeId}");
    }

    [Inject]
    private NavigationManager Navigation { get; set; } = default!;
}
