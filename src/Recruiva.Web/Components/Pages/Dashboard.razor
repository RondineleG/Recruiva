@page "/"
@page "/dashboard"
@using Recruiva.Core.DTOs.Response
@using Recruiva.Core.Enums
@using Recruiva.Core.UseCases.Jobs
@using Recruiva.Web.Services
@using Recruiva.Web.UseCases.Analytics
@inject SearchJobsUseCase SearchJobsUseCase
@inject GetDashboardAnalyticsUseCase DashboardAnalyticsUseCase
@inject ICurrentUserHelper CurrentUserHelper
@inject NavigationManager Navigation

<PageTitle>Dashboard - Recruiva</PageTitle>

<div class="container-fluid mt-4">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col">
            <h1>&#x1F4CA; Dashboard</h1>
            <p class="text-muted">Bem-vindo ao Recruiva - Sua plataforma de recrutamento</p>
        </div>
    </div>

    @if (isLoading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2">Carregando dashboard...</p>
        </div>
    }
    else
    {
        <!-- Estatísticas -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card bg-primary text-white">
                    <div class="card-body">
                        <h3><i class="bi bi-briefcase"></i> @analytics?.TotalJobs</h3>
                        <p class="mb-0">Total de Vagas</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-success text-white">
                    <div class="card-body">
                        <h3><i class="bi bi-check-circle"></i> @analytics?.ActiveJobs</h3>
                        <p class="mb-0">Vagas Ativas</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-info text-white">
                    <div class="card-body">
                        <h3><i class="bi bi-people"></i> @analytics?.TotalCandidates</h3>
                        <p class="mb-0">Candidatos</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card bg-warning text-white">
                    <div class="card-body">
                        <h3><i class="bi bi-send"></i> @analytics?.TotalApplications</h3>
                        <p class="mb-0">Candidaturas</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Gráfico de Vagas por Status -->
        @if (analytics?.JobsByStatus != null && analytics.JobsByStatus.Any())
        {
            <div class="row mb-4">
                <div class="col">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">&#x1F4CA; Vagas por Status</h5>
                            <div class="mt-3">
                                @foreach (var status in analytics.JobsByStatus)
                                {
                                    var percentage = analytics.TotalJobs > 0 ? (status.Value * 100 / analytics.TotalJobs) : 0;
                                    var bgColor = status.Key switch
                                    {
                                        "Active" => "bg-success",
                                        "Expired" => "bg-danger",
                                        "Paused" => "bg-warning",
                                        "Hidden" => "bg-secondary",
                                        "Rejected" => "bg-dark",
                                        _ => "bg-primary"
                                    };

                                    <div class="mb-2">
                                        <div class="d-flex justify-content-between">
                                            <span>@status.Key</span>
                                            <span>@status.Value (@percentage%)</span>
                                        </div>
                                        <div class="progress" style="height: 20px;">
                                            <div class="progress-bar @bgColor" role="progressbar" style="width: @percentage%" aria-valuenow="@percentage" aria-valuemin="0" aria-valuemax="100"></div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Gráfico de Candidaturas por Status -->
        @if (analytics?.ApplicationsByStatus != null && analytics.ApplicationsByStatus.Any())
        {
            <div class="row mb-4">
                <div class="col">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">&#x1F4EC; Candidaturas por Status</h5>
                            <div class="mt-3">
                                @foreach (var status in analytics.ApplicationsByStatus)
                                {
                                    var percentage = analytics.TotalApplications > 0 ? (status.Value * 100 / analytics.TotalApplications) : 0;
                                    var bgColor = status.Key switch
                                    {
                                        "Sent" => "bg-primary",
                                        "Viewed" => "bg-info",
                                        "Selected" => "bg-success",
                                        "Rejected" => "bg-danger",
                                        _ => "bg-secondary"
                                    };

                                    <div class="mb-2">
                                        <div class="d-flex justify-content-between">
                                            <span>@status.Key</span>
                                            <span>@status.Value (@percentage%)</span>
                                        </div>
                                        <div class="progress" style="height: 20px;">
                                            <div class="progress-bar @bgColor" role="progressbar" style="width: @percentage%" aria-valuenow="@percentage" aria-valuemin="0" aria-valuemax="100"></div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }

    <!-- Ações Rápidas -->
    <div class="row mb-4">
        <div class="col">
            <h4>&#x26A1; Ações Rápidas</h4>
        </div>
    </div>
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="bi bi-search display-6 text-primary"></i>
                    <h5 class="card-title mt-3">Buscar Vagas</h5>
                    <p class="card-text text-muted">Encontre a vaga ideal para você</p>
                    <button class="btn btn-primary" @onclick="NavigateToJobs">
                        Ver Vagas
                    </button>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="bi bi-plus-circle display-6 text-success"></i>
                    <h5 class="card-title mt-3">Criar Vaga</h5>
                    <p class="card-text text-muted">Publique uma nova vaga</p>
                    <button class="btn btn-success" @onclick="NavigateToCreateJob">
                        Nova Vaga
                    </button>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body text-center">
                    <i class="bi bi-file-earmark-text display-6 text-info"></i>
                    <h5 class="card-title mt-3">Meu Currículo</h5>
                    <p class="card-text text-muted">Gerencie seus currículos</p>
                    <button class="btn btn-info" @onclick="NavigateToResumes">
                        Ver Currículos
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Vagas Recentes -->
    <div class="row">
        <div class="col">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h4>&#x1F525; Vagas Recentes</h4>
                <button class="btn btn-outline-primary" @onclick="NavigateToJobs">
                    Ver Todas &rarr;
                </button>
            </div>
        </div>
    </div>

    @if (analytics?.RecentJobs != null && analytics.RecentJobs.Any())
    {
        <div class="row g-3">
            @foreach (var job in analytics.RecentJobs.Take(6))
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">@job.Title</h5>
                            @if (!string.IsNullOrEmpty(job.AdvertiserName))
                            {
                                <p class="text-muted mb-2">
                                    <i class="bi bi-building"></i> @job.AdvertiserName
                                </p>
                            }
                            @if (!string.IsNullOrEmpty(job.City))
                            {
                                <p class="text-muted mb-2">
                                    <i class="bi bi-geo-alt"></i> @job.City, @job.State
                                </p>
                            }
                            @if (job.SalaryDisplay && job.SalaryMin.HasValue && job.SalaryMax.HasValue)
                            {
                                <p class="text-success mb-2">
                                    <i class="bi bi-currency-exchange"></i>
                                    R$ @job.SalaryMin.Value.ToString("N2") - R$ @job.SalaryMax.Value.ToString("N2")
                                </p>
                            }
                            @if (!string.IsNullOrEmpty(job.Category))
                            {
                                <span class="badge bg-info">@job.Category</span>
                            }
                        </div>
                        <div class="card-footer bg-transparent">
                            <button class="btn btn-outline-primary w-100" @onclick="() => ViewJobDetails(job.Id)">
                                Ver Detalhes
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else if (!isLoading)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle"></i> Nenhuma vaga disponível no momento.
        </div>
    }
</div>

@code {
    private DashboardAnalyticsResponse? analytics;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        var advertiserId = CurrentUserHelper.GetAdvertiserId();

        var result = await DashboardAnalyticsUseCase.ExecuteAsync(advertiserId);
        if (result.Status == EResultStatus.Success)
        {
            analytics = result.Data;
        }

        isLoading = false;
    }

    private void ViewJobDetails(Guid jobId)
    {
        Navigation.NavigateTo($"/jobs/{jobId}");
    }

    private void NavigateToJobs()
    {
        Navigation.NavigateTo("/jobs");
    }

    private void NavigateToCreateJob()
    {
        Navigation.NavigateTo("/jobs/create");
    }

    private void NavigateToResumes()
    {
        Navigation.NavigateTo("/resumes");
    }
}
