<!-- Main Content -->
<main class="container-fluid mt-3">
    @Body
</main>

<!-- Footer -->
<footer class="bg-light text-center text-muted py-4 mt-5">
    <div class="container">
        <p>&copy; 2026 Recruiva. Todos os direitos reservados.</p>
        <p class="small">Plataforma gratuita de recrutamento</p>
    </div>
</footer>

<!-- Error UI -->
<div id="blazor-error-ui" class="alert alert-danger" style="display: none;">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>
