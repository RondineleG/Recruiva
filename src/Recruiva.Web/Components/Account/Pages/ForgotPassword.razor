@page "/Account/ForgotPassword"

@using System.ComponentModel.DataAnnotations
@using System.Text
@using System.Text.Encodings.Web
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.WebUtilities
@using Recruiva.Web.Models
@using Recruiva.Core.UseCases.Notifications
@using Recruiva.Core.Enums

@inject UserManager<ApplicationUser> UserManager
@inject IEmailSender<ApplicationUser> EmailSender
@inject PasswordResetUseCase PasswordResetUseCase
@inject NavigationManager NavigationManager
@inject IdentityRedirectManager RedirectManager
@inject ILogger<ForgotPassword> Logger

<PageTitle>Forgot your password?</PageTitle>

<h1>Forgot your password?</h1>
<h2>Enter your email.</h2>
<hr />

@if (!string.IsNullOrEmpty(successMessage))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle"></i> @successMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle"></i> @errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row">
    <div class="col-md-4">
        <EditForm Model="Input" FormName="forgot-password" OnValidSubmit="OnValidSubmitAsync" method="post">
            <DataAnnotationsValidator />
            <ValidationSummary class="text-danger" role="alert" />

            <div class="form-floating mb-3">
                <InputText @bind-Value="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                <label for="email" class="form-label">Email</label>
                <ValidationMessage For="() => Input.Email" class="text-danger" />
            </div>
            <button type="submit" class="w-100 btn btn-lg btn-primary" disabled="@isSubmitting">
                @(isSubmitting ? "Enviando..." : "Reset password")
            </button>
        </EditForm>
     </div>
</div>

@code {
    [SupplyParameterFromForm]
    private InputModel Input { get; set; } = new();

    private string? successMessage;
    private string? errorMessage;
    private bool isSubmitting;

    private async Task OnValidSubmitAsync()
    {
        isSubmitting = true;
        successMessage = null;
        errorMessage = null;

        var user = await UserManager.FindByEmailAsync(Input.Email);
        
        // Don't reveal that the user does not exist or is not confirmed
        if (user is null || !(await UserManager.IsEmailConfirmedAsync(user)))
        {
            // Ainda assim, enviamos o email se o usuário existir e estiver confirmado
            // Para segurança, sempre mostramos mensagem de sucesso
            RedirectManager.RedirectTo("Account/ForgotPasswordConfirmation");
            return;
        }

        // Gerar token de reset de senha
        var code = await UserManager.GeneratePasswordResetTokenAsync(user);
        code = WebEncoders.Base64UrlEncode(Encoding.UTF8.GetBytes(code));
        var callbackUrl = NavigationManager.GetUriWithQueryParameters(
            NavigationManager.ToAbsoluteUri("Account/ResetPassword").AbsoluteUri,
            new Dictionary<string, object?> { ["code"] = code, ["email"] = Input.Email });

        // Enviar email via IEmailSender (padrão Identity)
        await EmailSender.SendPasswordResetLinkAsync(user, Input.Email, HtmlEncoder.Default.Encode(callbackUrl));

        // Enviar email via PasswordResetUseCase (template rico)
        var passwordResetRequest = new PasswordResetRequest
        {
            Email = Input.Email,
            ResetLink = callbackUrl
        };

        var emailResult = await PasswordResetUseCase.ExecuteAsync(passwordResetRequest);
        if (emailResult.Status == EResultStatus.Success)
        {
            Logger.LogInformation("Email de recuperação de senha enviado para {Email}", Input.Email);
        }
        else
        {
            Logger.LogWarning("Falha ao enviar email de recuperação via UseCase: {Message}", emailResult.Message);
        }

        RedirectManager.RedirectTo("Account/ForgotPasswordConfirmation");
        isSubmitting = false;
    }

    private sealed class InputModel
    {
        [Required]
        [EmailAddress]
        public string Email { get; set; } = "";
    }
}