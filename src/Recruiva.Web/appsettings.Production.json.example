{
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_PRODUCTION_SERVER;Database=Recruiva.Production;User Id=YOUR_DB_USER;Password=YOUR_DB_PASSWORD;TrustServerCertificate=False;Encrypt=True;"
  },
  "SendGrid": {
    "ApiKey": "YOUR_SENDGRID_API_KEY",
    "FromEmail": "noreply@recruiva.com",
    "FromName": "Recruiva"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "your-domain.com"
}
